<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>
    <property>
        <name>mapreduce.framework.name</name>
        <value>yarn</value>
    </property>

    <property>
        <name>yarn.app.mapreduce.am.env</name>
        <value>HADOOP_MAPRED_HOME=/opt/bd/hadoop,HADOOP_HOME=/opt/bd/hadoop,HADOOP_CONF_DIR=/opt/bd/hadoop/etc/hadoop,JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64</value>
    </property>
    <property>
        <name>mapreduce.map.env</name>
        <value>HADOOP_MAPRED_HOME=/opt/bd/hadoop,HADOOP_HOME=/opt/bd/hadoop,HADOOP_CONF_DIR=/opt/bd/hadoop/etc/hadoop,JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64</value>
    </property>
    <property>
        <name>mapreduce.reduce.env</name>
        <value>HADOOP_MAPRED_HOME=/opt/bd/hadoop,HADOOP_HOME=/opt/bd/hadoop,HADOOP_CONF_DIR=/opt/bd/hadoop/etc/hadoop,JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64</value>
    </property>

    <property>
        <name>mapreduce.application.classpath</name>
        <value>/opt/bd/hadoop/etc/hadoop,/opt/bd/hadoop/share/hadoop/common/*,/opt/bd/hadoop/share/hadoop/common/lib/*,/opt/bd/hadoop/share/hadoop/hdfs/*,/opt/bd/hadoop/share/hadoop/hdfs/lib/*,/opt/bd/hadoop/share/hadoop/mapreduce/*,/opt/bd/hadoop/share/hadoop/mapreduce/lib/*,/opt/bd/hadoop/share/hadoop/yarn/*,/opt/bd/hadoop/share/hadoop/yarn/lib/*</value>
    </property>

    <property>
        <name>yarn.app.mapreduce.am.resource.mb</name>
        <value>2048</value>
    </property>
    <property>
        <name>yarn.app.mapreduce.am.command-opts</name>
        <value>-Xmx1638m --add-opens=java.base/java.lang=ALL-UNNAMED --add-opens=java.base/java.lang.reflect=ALL-UNNAMED --add-opens=java.base/java.io=ALL-UNNAMED --add-opens=java.rmi/sun.rmi.transport=ALL-UNNAMED</value>
    </property>

    <property>
        <name>mapreduce.map.memory.mb</name>
        <value>2048</value>
    </property>
    <property>
        <name>mapreduce.map.java.opts</name>
        <value>-Xmx1638m --add-opens=java.base/java.lang=ALL-UNNAMED --add-opens=java.base/java.lang.reflect=ALL-UNNAMED --add-opens=java.base/java.io=ALL-UNNAMED --add-opens=java.rmi/sun.rmi.transport=ALL-UNNAMED</value>
    </property>

    <property>
        <name>mapreduce.reduce.memory.mb</name>
        <value>4096</value>
    </property>
    <property>
        <name>mapreduce.reduce.java.opts</name>
        <value>-Xmx3276m --add-opens=java.base/java.lang=ALL-UNNAMED --add-opens=java.base/java.lang.reflect=ALL-UNNAMED --add-opens=java.base/java.io=ALL-UNNAMED --add-opens=java.rmi/sun.rmi.transport=ALL-UNNAMED</value>
    </property>
    
    <property>
        <name>mapreduce.job.running.map.limit</name>
        <value>60</value> 
    </property>
    <property>
        <name>mapreduce.job.running.reduce.limit</name>
        <value>24</value>
    </property>
</configuration>